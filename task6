<!DOCTYPE html>
<html>
<head>
    <title>Text Input Validation</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 100px;
            background-color: #f0f8ff;
        }

        input {
            padding: 10px;
            width: 250px;
            font-size: 16px;
        }

        button {
            padding: 10px 20px;
            margin-left: 10px;
            background-color: #28a745;
            color: white;
            border: none;
            cursor: pointer;
        }

        #result {
            margin-top: 20px;
            font-size: 18px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h2>Name Validation Form</h2>

    <input type="text" id="name" placeholder="Enter your name">
    <button onclick="validateInput()">Submit</button>

    <p id="result"></p>

    <script>
        function validateInput() {
            let name = document.getElementById("name").value;
            let result = document.getElementById("result");

            if (name.trim() === "") {
                result.innerHTML = "Please enter your name!";
                result.style.color = "red";
            } else {
                result.innerHTML = "Valid Input: " + name;
                result.style.color = "green";
            }
        }
    </script>

</body>
</html>
