body {
background-color: #e6f7ff;
font-family: Arial, sans-serif;
}

.container {
background-color: white;
width: 70%;
margin: 30px auto;
padding: 20px;
border: 2px solid skyblue;
}

h1 {
color: navy;
text-align: center;
}

h2 {
color: teal;
}

p {
font-size: 18px;
}

table {
width: 100%;
border-collapse: collapse;
}

th {
background-color: teal;
color: white;
}

th, td {
border: 1px solid black;
padding: 10px;
text-align: center;
}
