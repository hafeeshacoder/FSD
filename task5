<!DOCTYPE html>
<html>
<head>
    <title>Button Event Listener Example</title>
    <style>
        body{
            font-family: Arial, sans-serif;
            text-align: center;
            background-color: #f0f8ff;
            margin-top: 100px;
        }

        h1{
            color: #333;
        }

        button{
            padding: 12px 25px;
            font-size: 18px;
            border: none;
            border-radius: 8px;
            background-color: #007bff;
            color: white;
            cursor: pointer;
        }

        button:hover{
            background-color: #0056b3;
        }

        #message{
            margin-top: 20px;
            font-size: 22px;
            color: green;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h1>Event Listener Demo</h1>

    <button id="myButton">Click Me</button>

    <p id="message"></p>

    <script>
        const button = document.getElementById("myButton");
        const message = document.getElementById("message");

        button.addEventListener("click", 
		function() {
            message.textContent = "Button Clicked Successfully!";
        });
    </script>

</body>
</html>
